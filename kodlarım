            <p class="text-center w-100">Ürünler yükleniyor...</p>
        </div>
    </div>

    <script>
        
        window.onload = loadProducts;

        async function loadProducts() {
            try {
                const response = await fetch('http://localhost:5256/api/Products');
                const products = await response.json();
                displayProducts(products);
            } catch (err) {
                console.error("Hata:", err);
            }
        }

        async function filterByCategory(id) {
            try {
                const response = await fetch('http://localhost:5256/api/Products');
                const allProducts = await response.json();
                const filtered = allProducts.filter(p => p.categoryId == id);
                displayProducts(filtered);
            } catch (err) {
                console.error("Filtreleme hatası:", err);
            }
        }

        function displayProducts(products) {
    const list = document.getElementById("product-list");
    if (!list) return;

    list.innerHTML = "";

    products.forEach(p => {
        list.innerHTML += `
            <div class="col-md-3 mb-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                    <img src="${p.imagePath}" 
                         onerror="this.src='https://loremflickr.com/400/400/fashion,product?lock=${p.id}'"
                         class="card-img-top" 
                         style="height: 200px; object-fit: cover;">
                    <div class="card-body text-center">
                        <h6 class="fw-bold">${p.name}</h6>
                        <p class="text-primary fw-bold">₺${p.price.toLocaleString()}</p>
                        <a href="product-details.html?id=${p.id}" class="btn btn-outline-primary w-100 rounded-pill">İncele</a>
                        <button onclick="addToCart(${p.id}, '${p.name}', ${p.price})" class="btn btn-success w-100 rounded-pill mt-2">Sepete Ekle</button>
                    </div>
                </div>
            </div>`;
    });
}
       function addToCart(id, name, price) {
    
    let cart = JSON.parse(localStorage.getItem("cart")) || [];
    
    
    const product = { 
        id: parseInt(id), 
        name: name, 
        price: parseFloat(price) 
    };
    
    
    cart.push(product);
    localStorage.setItem("cart", JSON.stringify(cart));
    
    
    alert(name + " sepete eklendi!");
}

    </script>
