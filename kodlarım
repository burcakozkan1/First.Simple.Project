<body class="bg-light">
    <div class="container py-5">
        <div class="card shadow border-0 p-4">
            <h2 class="fw-bold mb-4">Yeni Ürün Ekle</h2>
            
            <form id="productForm">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Ürün Adı</label>
                        <input type="text" id="name" class="form-control" placeholder="Örn: Siyah Elbise" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Fiyat (TL)</label>
                        <input type="number" id="price" class="form-control" placeholder="0.00" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Açıklama</label>
                        <textarea id="description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Görsel URL</label>
                        <input type="text" id="imagePath" class="form-control" placeholder="https://...">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Kategori</label>
                        <select id="categoryId" class="form-select">
                            <option value="1">Giyim</option>
                            <option value="2">Aksesuar</option>
                        </select>
                    </div>
                    <div class="col-12 mt-4">
                        <button type="submit" class="btn btn-primary px-5 fw-bold">Kaydet</button>
                        <a href="index.html" class="btn btn-outline-secondary px-5">İptal</a>
                    </div>
                </div>
            </form>
            <div id="statusMessage" class="mt-3"></div>
        </div>
